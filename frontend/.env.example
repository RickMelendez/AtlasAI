# ── Atlas AI Frontend — Environment Variables ─────────────────────────────────
# For local dev: copy to .env.local and fill in values.
# For Vercel: set these as environment variables in the Vercel dashboard.

# Backend WebSocket URL
# Local:      ws://localhost:8000/api/ws
# Production: wss://your-backend.railway.app/api/ws
VITE_WS_URL=ws://localhost:8000/api/ws

# Backend HTTP API URL
# Local:      http://localhost:8000
# Production: https://your-backend.railway.app
VITE_API_URL=http://localhost:8000

# Sentry error tracking (optional)
VITE_SENTRY_DSN=

# App version
VITE_APP_VERSION=0.1.0
