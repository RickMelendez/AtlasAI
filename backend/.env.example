# ── Atlas AI Backend — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional: Text-to-Speech ──────────────────────────────────────────────────

# ElevenLabs (best quality voice)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=                 # leave blank for default Rachel voice

# Fish Audio (alternative TTS)
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=

# ── Optional: Integrations ────────────────────────────────────────────────────

# Notion integration — get token at https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key_here

# Sentry error tracking — get DSN at https://sentry.io
SENTRY_DSN=

# ── Deployment ────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins (no spaces)
# Example: https://atlas-ai.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=

# App Configuration
APP_NAME=Atlas AI Visual Companion
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./atlas.db

# Server
HOST=0.0.0.0
PORT=8000
